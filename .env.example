# Hynous Environment Variables
# Copy this to .env and fill in your values
# Never commit .env to git!

# Anthropic (Claude)
ANTHROPIC_API_KEY=sk-ant-api03-...

# Hyperliquid (for live trading - not needed for paper)
HYPERLIQUID_API_KEY=
HYPERLIQUID_API_SECRET=

# CryptoQuant (optional - for on-chain data)
CRYPTOQUANT_API_KEY=

# Alpaca (stocks paper trading)
ALPACA_API_KEY_ID=
ALPACA_API_SECRET_KEY=

# TradingView webhook shared secret
TRADINGVIEW_WEBHOOK_TOKEN=
